{
  "name": "trademind-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "./node_modules/.bin/expo start",
    "android": "env PATH=./bin:./node_modules/.bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin LANG=en_US.UTF-8 npm_config_registry=https://registry.npmjs.org/ expo run:android",
    "ios": "env PATH=./bin:./node_modules/.bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin LANG=en_US.UTF-8 npm_config_registry=https://registry.npmjs.org/ expo run:ios",
    "prebuild": "env PATH=./bin:./node_modules/.bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin LANG=en_US.UTF-8 npm_config_registry=https://registry.npmjs.org/ expo prebuild",
    "pods": "cd ios && ../bin/pod install --repo-update --ansi",
    "web": "./node_modules/.bin/expo start --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@tanstack/react-query": "^5.62.7",
    "expo": "~52.0.0",
    "expo-router": "~4.0.0",
    "firebase": "^12.10.0",
    "lucide-react-native": "^0.372.0",
    "react": "^18.3.1",
    "react-native": "0.76.9",
    "react-native-svg": "^15.3.0",
    "victory-native": "^36.6.8"
  }
}
